FLASK_ENV=development
SECRET_KEY=wms-dev-secret-key-32chars-min!!
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=wmspassword
MYSQL_DATABASE=wmsdatabase
JWT_EXPIRE_HOURS=24

# Orange Pi Zero 2W GPIO（物理引脚7 = PC9 = gpiochip1 line 73）
GPIO_ENABLED=false
